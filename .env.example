DATABASE_URL=postgresql://docuser:docpass@localhost:5432/docjobs
REDIS_URL=redis://localhost:6379/0

# Optional: public URL reviewers should call (no trailing slash). Adds an OpenAPI "Server" in /docs.
# Local default is http://localhost:8000 — set when deployed, e.g. https://your-api.example.com
# API_PUBLIC_BASE_URL=https://your-api.example.com

# POST /v1/jobs throttle (SlowAPI)
API_RATE_LIMIT=60/minute
READ_RATE_LIMIT=120/minute

# Set to e.g. 0.3 to randomly fail jobs (exercises Celery retries)
SIMULATE_RANDOM_FAILURE_RATE=0.0
